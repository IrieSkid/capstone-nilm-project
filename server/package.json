{
  "name": "nilm-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:reset": "tsx src/scripts/reset-db.ts",
    "db:migrate:rbac": "tsx src/scripts/migrate-add-rbac.ts",
    "db:migrate:landlord": "tsx src/scripts/migrate-add-landlord-module.ts",
    "db:migrate:billing": "tsx src/scripts/migrate-add-billing-module.ts",
    "db:migrate:notifications": "tsx src/scripts/migrate-add-notification-alerts.ts",
    "db:sync:appliances": "tsx src/scripts/sync-appliance-catalog.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "feeder": "tsx src/scripts/readings-feeder.ts",
    "feeder:dev": "tsx watch src/scripts/readings-feeder.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "mysql2": "^3.15.3",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
